{
	"name": "@maxal_studio/kratosjs-koa",
	"version": "3.0.2",
	"description": "Koa HTTP adapter for KratosJs admin panels",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "npm run clean && tsc -p tsconfig.json",
		"clean": "rm -rf dist",
		"lint": "eslint ./src",
		"test": "vitest run"
	},
	"keywords": [
		"kratosjs",
		"koa",
		"http-adapter"
	],
	"author": "MaxAl",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/maxal-studio/kratosjs.git"
	},
	"peerDependencies": {
		"@maxal_studio/kratosjs": "^3.0.2"
	},
	"dependencies": {
		"@koa/bodyparser": "^6.1.0",
		"@koa/router": "^15.7.0",
		"koa": "^3.2.1"
	},
	"devDependencies": {
		"@maxal_studio/kratosjs": "^3.0.2",
		"@types/koa": "^3.0.3",
		"@types/koa__router": "^12.0.5",
		"@types/node": "^25.9.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	}
}
