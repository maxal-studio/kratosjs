{
	"name": "@maxal_studio/kratosjs-express",
	"version": "3.0.1",
	"description": "Express HTTP adapter for KratosJs admin panels",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "npm run clean && tsc -p tsconfig.json",
		"clean": "rm -rf dist",
		"lint": "eslint ./src",
		"test": "vitest run"
	},
	"keywords": [
		"kratosjs",
		"kratosjs-plugin",
		"express",
		"http-adapter"
	],
	"author": "MaxAl",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/maxal-studio/kratosjs.git"
	},
	"peerDependencies": {
		"@maxal_studio/kratosjs": "^3.0.1"
	},
	"dependencies": {
		"cors": "^2.8.6",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@maxal_studio/kratosjs": "^3.0.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	}
}
