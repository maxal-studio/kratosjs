{
	"name": "@maxal_studio/kratosjs-react",
	"version": "1.0.2",
	"description": "React components for KratosJs form builder",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./app": {
			"types": "./dist/app.d.ts",
			"import": "./dist/app.js"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"import": "./dist/plugin.js"
		},
		"./styles.css": "./dist/styles.css",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"src",
		"vite.config.ts",
		"tailwind.config.js",
		"README.md"
	],
	"scripts": {
		"build": "npm run clean && tsc && vite build",
		"clean": "rm -rf dist",
		"dev": "tsc --watch",
		"lint": "eslint ./src",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"react",
		"forms",
		"form-builder",
		"kratosjs",
		"tailwind"
	],
	"author": "MaxAl",
	"email": "info@max.al",
	"website": "https://max.al",
	"license": "ISC",
	"peerDependencies": {
		"@maxal_studio/kratosjs": "^1.0.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.0.0"
	},
	"peerDependenciesMeta": {
		"@maxal_studio/kratosjs": {
			"optional": true
		}
	},
	"dependencies": {
		"@tiptap/extension-color": "^3.26.1",
		"@tiptap/extension-highlight": "^3.26.1",
		"@tiptap/extension-image": "^3.26.1",
		"@tiptap/extension-link": "^3.26.1",
		"@tiptap/extension-placeholder": "^3.26.1",
		"@tiptap/extension-subscript": "^3.26.1",
		"@tiptap/extension-superscript": "^3.26.1",
		"@tiptap/extension-text-align": "^3.26.1",
		"@tiptap/extension-text-style": "^3.26.1",
		"@tiptap/extension-underline": "^3.26.1",
		"@tiptap/react": "^3.26.1",
		"@tiptap/starter-kit": "^3.26.1",
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.18.0",
		"react-chartjs-2": "^5.3.1",
		"react-dropzone": "^15.0.0",
		"react-router-dom": "^7.17.0"
	},
	"devDependencies": {
		"@maxal_studio/kratosjs": "file:../..",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.79.0",
		"eslint": "^9.39.4",
		"jsdom": "^29.1.1",
		"typescript-eslint": "^8.61.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.5",
		"vitest": "^4.1.8"
	}
}
