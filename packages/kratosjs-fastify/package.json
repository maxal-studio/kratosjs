{
	"name": "@maxal_studio/kratosjs-fastify",
	"version": "3.0.0",
	"description": "Fastify HTTP adapter for KratosJs admin panels",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "npm run clean && tsc -p tsconfig.json",
		"clean": "rm -rf dist",
		"lint": "eslint ./src",
		"test": "vitest run"
	},
	"keywords": [
		"kratosjs",
		"kratosjs-plugin",
		"fastify",
		"http-adapter"
	],
	"author": "MaxAl",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/maxal-studio/kratosjs.git"
	},
	"peerDependencies": {
		"@maxal_studio/kratosjs": "^3.0.0"
	},
	"dependencies": {
		"@fastify/cors": "^11.3.0",
		"@fastify/middie": "^9.3.3",
		"@fastify/static": "^9.3.0",
		"fastify": "^5.10.0"
	},
	"devDependencies": {
		"@maxal_studio/kratosjs": "^3.0.0",
		"@types/node": "^25.9.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	}
}
